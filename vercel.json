{
  "headers": [
    {
      "source": "/(player|index|dev|admin|lobby|grading-test)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/build.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/odds/mlb",
      "destination": "/api/odds/mlb"
    },
    {
      "source": "/api/sportsdataio/:path*",
      "destination": "/api/sportsdataio/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://pocketbooks-sports-backend-production.up.railway.app/api/:path*"
    }
  ]
}
